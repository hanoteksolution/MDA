# Public URL for the cloud platform (browser + desktop sync).
# Change this to your domain when DNS points to the VPS (A record → 88.222.220.238).
#
# Examples:
#   MDA_PUBLIC_URL=http://erp.yourcompany.com:8010
#   MDA_PUBLIC_URL=https://erp.yourcompany.com
#
# After changing, redeploy (python scripts/deploy_vps_update.py) and rebuild desktop (make build-desktop).

MDA_PUBLIC_URL=https://erp.safaritechno.com
